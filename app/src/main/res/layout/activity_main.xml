<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- URL Switch Buttons -->
    <LinearLayout
        android:id="@+id/urlSwitchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:background="#E0000000"
        android:padding="4dp"
        android:gravity="center"
        android:alpha="0.9"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/btnTest"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center"
            android:text="Test"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/btnWebui"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center"
            android:text="WebUI"
            android:textColor="#999999"
            android:textSize="13sp"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center"
            android:text="Clear"
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_gravity="top"
        android:progressDrawable="@drawable/progress_drawable"
        android:visibility="gone" />

    <!-- Error View -->
    <LinearLayout
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_report_image"
            android:alpha="0.5"
            android:contentDescription="@string/error_icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/load_failed"
            android:textColor="#666666"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/check_network"
            android:textColor="#999999"
            android:textSize="14sp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/retry" />

    </LinearLayout>

    <!-- MCP Status Panel -->
    <LinearLayout
        android:id="@+id/mcpStatusPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#E0000000"
        android:padding="8dp"
        android:alpha="0.9">

        <!-- Header with status indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/mcpStatusIndicator"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/status_indicator_disconnected" />

            <TextView
                android:id="@+id/mcpStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="MCP: 未连接"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/mcpToggleBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="展开"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Expandable content -->
        <LinearLayout
            android:id="@+id/mcpDetailPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最后调用:"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/mcpLastTool"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="返回结果:"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/mcpLastResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:maxLines="3"
                android:ellipsize="end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日志:"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/mcpLog"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="等待 MCP 连接..."
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:maxLines="4"
                android:ellipsize="end"
                android:scrollbars="vertical" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
